flowchart TD

    User(["👤 User — Browser or API Client"])

    subgraph AWS["☁️ AWS Cloud — us-east-1"]

        ALB["🔀 ALB Load Balancer\nPort 80 → App   |   Port 8001 → Red Team"]

        subgraph Security["🔒 Security — every request goes through this"]
            direction LR
            Auth["API Key Check\nX-API-Key header\n401 if wrong"]
            Rate["Rate Limiter\n10 requests / 60s per IP\nTracked in Redis"]
            GIn["Bedrock Guardrail\nInput Scan\nBlocks: harmful topics, PII,\nprompt attacks, weapons"]
        end

        Queue["📨 Redis Stream — Job Queue\nRequest is queued and processed in background"]

        subgraph SmartCache["⚡ Smart Lookup — checked before calling any LLM"]
            direction LR
            Cache["Semantic Cache\nRedis\nSame-ish topic asked before?\n→ return instantly, skip agents"]
            LTMExact["LTM Exact Match\nPostgreSQL + pgvector\nSame topic in last 7 days?\n→ return stored report"]
            LTMRelated["LTM Related Context\nPostgreSQL + pgvector\nSimilar topic found?\n→ pass old report to Writer Agent\nas reference — agents still run"]
        end

        subgraph LangGraph["🤖 LangGraph — 4 AI Agents run in sequence"]
            direction LR
            S1["① Search Agent\nFinds 5 key facts\nabout the topic\nUses session history\nso it knows what user asked before"]
            S2["② Summarize Agent\nCondenses raw\nresearch findings\ninto bullet points"]
            S3["③ Writer Agent\nWrites the full report\nExecutive Summary\nKey Findings · Analysis\nConclusion\nUses related past research\nif LTM found any"]
            S4["④ Critic Agent\nFact-checks the report\nReturns YES or NO\nIf NO → loops back\nto Search Agent\nup to 3 retries"]
        end

        TZ["🔀 TensorZero — LLM Gateway\nAll agent calls go through here\nPrimary: OpenAI GPT-4o\nFallback: Groq llama-3.1-8b-instant\nAuto-routes on failure"]

        GOut["🛡️ Bedrock Guardrail\nOutput Scan\nBlocks harmful content\nbefore returning to user"]

        subgraph Save["💾 Save & Evaluate — runs after every report"]
            direction LR
            Store["Store Results\nCache → Redis\nReport → PostgreSQL pgvector\nSession turn → Redis"]
            Eval["LLM-as-Judge Evaluation\nLangSmith · 4 scores per report\nRelevance · Completeness\nHallucination Risk · Quality"]
        end

        subgraph Datastores["🗄️ Storage Layer"]
            direction LR
            Redis["Redis — ElastiCache\nSemantic cache\nSession memory\nJob queue + results"]
            RDS["PostgreSQL + pgvector — RDS\nStores all reports\n384-dimension vector embeddings\nFast similarity search\nSentenceTransformer all-MiniLM-L6-v2"]
        end

        subgraph RedTeam["🔴 PyRIT Red Team — separate container"]
            PyRIT["PyRIT 0.14.0\nAutomated security attacks\nJailbreak · XPIA\nCrescendo · Skeleton Key\nResults saved to Redis\nRuns weekly — every Monday 2am UTC"]
        end

        Secrets["🔐 Secrets Manager\nresearch-agent/config\nHolds all API keys + config\nApp reads this on startup"]
        ECR["📦 ECR — Docker Registry\nStores 3 images:\napp · pyrit · tensorzero"]
        CW["📋 CloudWatch\nContainer logs\n7-day retention"]
        EB["⏰ EventBridge\nSchedule trigger\nMonday 02:00 UTC"]
        Bedrock["AWS Bedrock Guardrails"]

    end

    subgraph LLMs["🧠 LLM Providers — outside AWS"]
        GPT4o["OpenAI GPT-4o\nPrimary model"]
        Groq["Groq\nllama-3.1-8b-instant\nFallback model"]
    end

    LangSmith["📊 LangSmith\nTraces every agent node\nStores 4 eval scores per report\nProject: research-agent"]

    subgraph CICD["🔄 CI/CD + Infrastructure as Code"]
        direction LR
        GH["GitHub Actions\ndeploy.yml\nOn every git push:\nBuild 3 Docker images\nPush to ECR\nDeploy to ECS\nWait for stability\nAuto rollback if it fails"]
        TF["Terraform\nterraform/main.tf\nCreates all AWS resources\nVPC · Subnets · ECS · ALB\nElastiCache · RDS · ECR\nBedrock Guardrail\nSecrets Manager · IAM roles\nAuto-scaling · EventBridge\nState: S3 + DynamoDB lock"]
    end

    %% ── Main Request Flow ──────────────────────────────────
    User -->|"1 — sends request"| ALB
    ALB --> Auth --> Rate --> GIn
    GIn -->|"safe — push to queue"| Queue
    Queue --> Cache
    Cache -->|"miss"| LTMExact
    LTMExact -->|"miss"| LTMRelated
    LTMRelated --> S1 --> S2 --> S3 --> S4
    S4 -->|"critic fails — retry"| S1
    S4 -->|"critic passes"| GOut
    Cache -->|"hit — skip agents"| GOut
    LTMExact -->|"hit — skip agents"| GOut
    GOut --> Store --> Eval

    %% ── LLM Calls ──────────────────────────────────────────
    S1 & S2 & S3 & S4 & Eval -->|"POST /inference"| TZ
    TZ --> GPT4o
    TZ -->|"if GPT-4o fails"| Groq

    %% ── Storage Read/Write ─────────────────────────────────
    Cache & Store <-->|"read / write"| Redis
    LTMExact & LTMRelated & Store <-->|"vector search / insert"| RDS
    GIn & GOut --> Bedrock

    %% ── Observability ──────────────────────────────────────
    S1 & S2 & S3 & S4 & Eval -->|"@traceable"| LangSmith

    %% ── Red Team ───────────────────────────────────────────
    ALB --> PyRIT
    PyRIT -->|"attack requests"| ALB
    EB -->|"weekly trigger"| PyRIT

    %% ── Infra ──────────────────────────────────────────────
    ALB & Queue & Redis & RDS & Bedrock & Secrets & ECR & CW & EB --> AWS
    GH -->|"push images"| ECR
    GH -->|"update ECS service"| LangGraph
    TF -.->|"provisions everything"| AWS
    LangGraph -->|"logs"| CW
    LangGraph -->|"reads API keys"| Secrets
